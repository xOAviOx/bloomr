doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Profile | Bloomr
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    style.
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #141414;
        --bg-tertiary: #1a1a1a;
        --text-primary: #f5f5f5;
        --text-secondary: #888888;
        --text-muted: #555555;
        --accent: #e63946;
        --accent-hover: #ff4d5a;
        --border: #2a2a2a;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Sora', sans-serif;
        background: var(--bg-primary);
        min-height: 100vh;
        color: var(--text-primary);
      }
      .background {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 0;
        background: radial-gradient(ellipse at 20% 20%, rgba(230, 57, 70, 0.06) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 80%, rgba(230, 57, 70, 0.04) 0%, transparent 50%);
      }
      .header {
        position: fixed; top: 0; left: 0; right: 0;
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        z-index: 100;
        display: flex; justify-content: space-between; align-items: center;
      }
      .logo {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 24px; font-weight: 700;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav { display: flex; gap: 24px; align-items: center; }
      .nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px; font-weight: 500;
        transition: color 0.3s ease;
      }
      .nav a:hover, .nav a.active { color: var(--accent); }
      .logout-btn {
        padding: 8px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 13px;
        transition: all 0.3s ease;
      }
      .logout-btn:hover { background: var(--accent); border-color: var(--accent); color: white; }
      .container {
        position: relative; z-index: 1;
        max-width: 700px;
        margin: 0 auto;
        padding: 100px 20px 40px;
      }
      .profile-header {
        display: flex; gap: 32px; align-items: center;
        margin-bottom: 40px;
      }
      .avatar-wrapper { position: relative; }
      .avatar {
        width: 120px; height: 120px;
        border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 40px;
        color: var(--accent);
        overflow: hidden;
        border: 3px solid var(--border);
      }
      .avatar img { width: 100%; height: 100%; object-fit: cover; }
      .user-info h1 { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 600; margin-bottom: 4px; }
      .user-info p { color: var(--text-secondary); font-size: 14px; }
      .user-info .joined { font-size: 12px; color: var(--text-muted); margin-top: 8px; }
      .stats { display: flex; gap: 32px; margin: 16px 0; }
      .stat { text-align: center; cursor: pointer; transition: color 0.3s ease; }
      .stat:hover { color: var(--accent); }
      .stat .num { font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700; }
      .stat .label { font-size: 12px; color: var(--text-muted); }
      .section {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px;
        margin-bottom: 24px;
      }
      .section h2 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 600; margin-bottom: 20px; }
      .form-group { margin-bottom: 20px; }
      .form-group:last-child { margin-bottom: 0; }
      .form-group label { display: block; font-size: 13px; font-weight: 500; color: var(--text-secondary); margin-bottom: 8px; }
      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 14px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        outline: none;
        transition: border-color 0.3s ease;
      }
      .form-group input:focus,
      .form-group textarea:focus { border-color: var(--accent); }
      .form-group input::placeholder,
      .form-group textarea::placeholder { color: var(--text-muted); }
      .form-group textarea { resize: none; min-height: 100px; }
      .form-group .hint { font-size: 11px; color: var(--text-muted); margin-top: 6px; }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .save-btn {
        padding: 14px 28px;
        background: var(--accent);
        border: none;
        border-radius: 10px;
        color: white;
        font-family: 'Sora', sans-serif;
        font-size: 14px; font-weight: 600;
        cursor: pointer;
        transition: background 0.3s ease;
      }
      .save-btn:hover { background: var(--accent-hover); }
      .cancel-btn {
        padding: 14px 28px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-secondary);
        font-family: 'Sora', sans-serif;
        font-size: 14px; font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-left: 12px;
      }
      .cancel-btn:hover { background: var(--border); }
      .delete-btn {
        padding: 14px 28px;
        background: transparent;
        border: 1px solid #e63946;
        border-radius: 10px;
        color: #e63946;
        font-family: 'Sora', sans-serif;
        font-size: 14px; font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .delete-btn:hover { background: #e63946; color: white; }
      .actions { display: flex; gap: 12px; margin-top: 24px; }
      .message {
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
      }
      .message.success { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); color: #22c55e; }
      .message.error { background: rgba(230, 57, 70, 0.1); border: 1px solid rgba(230, 57, 70, 0.3); color: var(--accent); }
      .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 200;
        align-items: center; justify-content: center;
      }
      .modal-overlay.active { display: flex; }
      .modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
        width: 100%;
        max-width: 500px;
        margin: 20px;
      }
      .modal h2 { font-family: 'Space Grotesk', sans-serif; font-size: 20px; margin-bottom: 24px; }
      .modal-list { max-height: 300px; overflow-y: auto; }
      .modal-item { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); }
      .modal-item:last-child { border-bottom: none; }
      .modal-item .avatar { width: 40px; height: 40px; font-size: 14px; border-radius: 50%; background: var(--bg-tertiary); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--accent); overflow: hidden; flex-shrink: 0; }
      .modal-item .avatar img { width: 100%; height: 100%; object-fit: cover; }
      .modal-item .info { flex: 1; }
      .modal-item .info a { text-decoration: none; color: inherit; display: block; }
      .modal-item .info h4 { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
      .modal-close {
        display: block; width: 100%; margin-top: 16px;
        padding: 12px; background: var(--bg-tertiary); border: 1px solid var(--border);
        border-radius: 10px; color: var(--text-secondary); font-family: 'Sora', sans-serif;
        font-size: 14px; cursor: pointer; text-align: center;
      }
      .modal-close:hover { background: var(--border); }
  body
    .background
    .header
      .logo Bloomr
      .nav
        a(href="/home") Home
        a(href="/internships") Internships
        a(href="/profile" class="active") Profile
        a.logout-btn(href="/logout") Logout
    .container
      .profile-header
        .avatar-wrapper
          .avatar
            if user.photo && user.photo !== "default.jpg"
              img(src=user.photo alt=user.name)
            else
              = user.name ? user.name.charAt(0).toUpperCase() : '?'
        .user-info
          h1= user.name
          p= user.email
          .joined Joined #{new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
          .stats
            .stat(id="profile-followers-stat")
              .num= user.followers ? user.followers.length : 0
              .label Followers
            .stat(id="profile-following-stat")
              .num= user.following ? user.following.length : 0
              .label Following
      if locals.success
        .message.success= success
      if locals.error
        .message.error= error
      .section
        h2 Personal Information
        form(action="/profile/update" method="POST" enctype="multipart/form-data")
          .form-row
            .form-group
              label(for="name") Username
              input(type="text" id="name" name="name" value=user.name required minlength="8" maxlength="15")
            .form-group
              label(for="email") Email
              input(type="email" id="email" name="email" value=user.email required)
          .form-group
            label(for="bio") Bio
            textarea(id="bio" name="bio" maxlength="200" placeholder="Tell us about yourself...")= user.bio
            .hint= (user.bio ? user.bio.length : 0) + "/200"
          .form-group
            label(for="photo") Profile Photo
            input(type="file" id="photo" name="photo" accept="image/*")
            .hint Upload an image (jpeg, jpg, png, gif, webp) or leave empty to keep current
          .actions
            button(type="submit").save-btn Save Changes
      .section
        h2 Change Password
        form(action="/profile/password" method="POST")
          .form-group
            label(for="currentPassword") Current Password
            input(type="password" id="currentPassword" name="currentPassword" placeholder="Enter current password" required)
          .form-row
            .form-group
              label(for="newPassword") New Password
              input(type="password" id="newPassword" name="newPassword" placeholder="Min 8 characters" required minlength="8" maxlength="15")
            .form-group
              label(for="confirmPassword") Confirm Password
              input(type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required minlength="8" maxlength="15")
          .actions
            button(type="submit").save-btn Update Password
      .section
        h2 Danger Zone
        .actions
          button.delete-btn(onclick="if(confirm('Are you sure? This cannot be undone.')) document.getElementById('deleteForm').submit();") Delete Account
          form(id="deleteForm" action="/profile/delete" method="POST" style="display:none")
    #followers-modal.modal-overlay
      .modal
        h2 Followers
        .modal-list#followers-list
        button.modal-close(type="button" onclick="document.getElementById('followers-modal').classList.remove('active')") Close
    #following-modal.modal-overlay
      .modal
        h2 Following
        .modal-list#following-list
        button.modal-close(type="button" onclick="document.getElementById('following-modal').classList.remove('active')") Close
    script.
      document.getElementById('profile-followers-stat').addEventListener('click', () => loadList('followers', '/api/v1/users/#{user._id}/followers'));
      document.getElementById('profile-following-stat').addEventListener('click', () => loadList('following', '/api/v1/users/#{user._id}/following'));

      async function loadList(type, url) {
        try {
          const res = await fetch(url);
          const data = await res.json();
          if (data.status !== 'success') return;
          const list = document.getElementById(`${type}-list`);
          list.innerHTML = '';
          data.data[type].forEach(u => {
            list.innerHTML += `
              <div class="modal-item">
                <div class="avatar">${u.photo && u.photo !== 'default.jpg' ? `<img src="${u.photo}" alt="${u.name}">` : u.name.charAt(0).toUpperCase()}</div>
                <div class="info">
                  <a href="/user/${u._id}"><h4>${u.name}</h4></a>
                </div>
              </div>
            `;
          });
          if (data.data[type].length === 0) {
            list.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 20px;">No users yet.</p>';
          }
          document.getElementById(`${type}-modal`).classList.add('active');
        } catch (err) {
          console.error('Failed to load list:', err);
        }
      }
