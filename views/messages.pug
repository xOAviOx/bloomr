doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Messages | Bloomr
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    script(src="https://cdn.socket.io/4.7.4/socket.io.min.js")
    style.
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #141414;
        --bg-tertiary: #1a1a1a;
        --text-primary: #f5f5f5;
        --text-secondary: #888888;
        --text-muted: #555555;
        --accent: #e63946;
        --accent-hover: #ff4d5a;
        --border: #2a2a2a;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Sora', sans-serif;
        background: var(--bg-primary);
        min-height: 100vh;
        color: var(--text-primary);
      }
      .background {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 0;
        background: radial-gradient(ellipse at 20% 20%, rgba(230, 57, 70, 0.06) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 80%, rgba(230, 57, 70, 0.04) 0%, transparent 50%);
      }
      .header {
        position: fixed; top: 0; left: 0; right: 0;
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        z-index: 100;
        display: flex; justify-content: space-between; align-items: center;
      }
      .logo {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 24px; font-weight: 700;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav { display: flex; gap: 24px; align-items: center; }
      .nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px; font-weight: 500;
        transition: color 0.3s ease;
      }
      .nav a:hover, .nav a.active { color: var(--accent); }
      .logout-btn {
        padding: 8px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 13px;
        transition: all 0.3s ease;
      }
      .logout-btn:hover { background: var(--accent); border-color: var(--accent); color: white; }
      .notification-bell {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 18px;
        text-decoration: none;
      }
      .notification-bell:hover { background: var(--accent); border-color: var(--accent); }
      .notification-bell .badge {
        position: absolute;
        top: -2px;
        right: -2px;
        background: var(--accent);
        color: white;
        font-size: 10px;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
      }
      .notification-bell .badge.hidden { display: none; }
      .messages-container {
        position: relative; z-index: 1;
        display: flex;
        height: calc(100vh - 65px);
        margin-top: 65px;
        max-width: 1100px;
        margin-left: auto; margin-right: auto;
        padding: 0 20px;
        gap: 20px;
      }
      .conversations-list {
        width: 320px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
      }
      .conversations-header {
        padding: 20px;
        border-bottom: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
      }
      .conversations-header h2 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 600; }
      .conversations-scroll { flex: 1; overflow-y: auto; }
      .conversation-item {
        display: flex; align-items: center; gap: 12px;
        padding: 16px 20px;
        cursor: pointer;
        transition: background 0.2s ease;
        border-bottom: 1px solid var(--border);
      }
      .conversation-item:hover { background: var(--bg-tertiary); }
      .conversation-item.active { background: var(--bg-tertiary); }
      .conversation-item .avatar {
        width: 48px; height: 48px; border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 600; font-size: 16px; color: var(--accent);
        overflow: hidden; flex-shrink: 0;
      }
      .conversation-item .avatar img { width: 100%; height: 100%; object-fit: cover; }
      .conversation-item .info { flex: 1; min-width: 0; }
      .conversation-item .info h4 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
      .conversation-item .info p { font-size: 12px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .conversation-item .meta { text-align: right; flex-shrink: 0; }
      .conversation-item .meta span { font-size: 11px; color: var(--text-muted); display: block; }
      .conversation-item .unread-badge {
        display: inline-block; width: 20px; height: 20px;
        background: var(--accent); border-radius: 50%;
        font-size: 10px; font-weight: 700; color: white;
        text-align: center; line-height: 20px; margin-top: 4px;
      }
      .chat-window {
        flex: 1;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .chat-header {
        padding: 20px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 12px;
      }
      .chat-header .avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 600; font-size: 14px; color: var(--accent);
        overflow: hidden; flex-shrink: 0;
      }
      .chat-header .avatar img { width: 100%; height: 100%; object-fit: cover; }
      .chat-header .info h3 { font-size: 15px; font-weight: 600; }
      .chat-header .info a { color: inherit; text-decoration: none; }
      .chat-messages {
        flex: 1; overflow-y: auto;
        padding: 20px;
        display: flex; flex-direction: column; gap: 12px;
      }
      .chat-empty { text-align: center; padding: 60px 20px; color: var(--text-secondary); }
      .chat-empty h3 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; margin-bottom: 8px; color: var(--text-primary); }
      .message {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 14px; line-height: 1.5;
      }
      .message.sent {
        align-self: flex-end;
        background: var(--accent);
        color: white;
        border-bottom-right-radius: 4px;
      }
      .message.received {
        align-self: flex-start;
        background: var(--bg-tertiary);
        color: var(--text-primary);
        border-bottom-left-radius: 4px;
      }
      .message .time { font-size: 10px; opacity: 0.7; margin-top: 4px; display: block; }
      .chat-input-area {
        padding: 16px 20px;
        border-top: 1px solid var(--border);
        display: flex; gap: 12px;
      }
      .chat-input-area input {
        flex: 1;
        padding: 12px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        outline: none;
      }
      .chat-input-area input:focus { border-color: var(--accent); }
      .chat-input-area button {
        padding: 12px 20px;
        background: var(--accent);
        border: none;
        border-radius: 12px;
        color: white;
        font-family: 'Sora', sans-serif;
        font-size: 14px; font-weight: 600;
        cursor: pointer;
        transition: background 0.3s ease;
      }
      .chat-input-area button:hover { background: var(--accent-hover); }
      .chat-input-area button:disabled { opacity: 0.5; cursor: not-allowed; }
      .no-messages { text-align: center; color: var(--text-muted); font-size: 13px; padding: 20px; }
      @media (max-width: 768px) {
        .messages-container { flex-direction: column; }
        .conversations-list { width: 100%; max-height: 300px; }
        .chat-window { min-height: 400px; }
      }
  body
    .background
    .header
      .logo Bloomr
      .nav
        a(href="/home") Home
        a(href="/internships") Internships
        a(href="/messages" class="active") Messages
        a(href="/profile") Profile
        a.notification-bell(id="navNotificationBell" href="/notifications")
          | 🔔
          .badge(id="navBadge" class=(unreadCount === 0 ? "hidden" : ""))= unreadCount > 99 ? '99+' : unreadCount
        a.logout-btn(href="/logout") Logout
    .messages-container
      .conversations-list
        .conversations-header
          h2 Messages
        .conversations-scroll#conversationsList
          .no-messages Loading conversations...
      .chat-window
        .chat-header#chatHeader
          .chat-empty-title Select a conversation to start chatting
        .chat-messages#chatMessages
          .chat-empty Click on a conversation on the left to start messaging
        .chat-input-area
          input(type="text" id="messageInput" placeholder="Type a message..." disabled onkeypress="if(event.key==='Enter')sendMessage()")
          button(id="sendBtn" onclick="sendMessage()" disabled) Send
    script.
      let socket;
      let currentChatUser = null;
      let conversations = [];
      const preSelectedChat = '!{preSelectedChat ? preSelectedChat : "null"}';

      // Initialize socket connection
      function initSocket() {
        try {
          socket = io({
            auth: { token: getCookie('jwt') }
          });

          socket.on('connect', () => {
            console.log('Socket connected');
            // Auto-open chat if pre-selected
            if (preSelectedChat && preSelectedChat !== 'null') {
              setTimeout(() => resolvePreSelectedChat(preSelectedChat), 500);
            }
          });

          socket.on('connect_error', (err) => {
            console.error('Socket connection error:', err.message);
          });

          socket.on('new_message', (message) => {
            if (currentChatUser && message.sender._id === currentChatUser._id) {
              appendMessage(message, 'received');
              document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight;
            }
            loadConversations();
          });

          socket.on('messages_read', () => {
            loadConversations();
          });

          socket.on('notification', (data) => {
            const badge = document.getElementById('navBadge');
            if (badge) {
              let count = parseInt(badge.textContent) || 0;
              if (badge.classList.contains('hidden')) count = 0;
              count++;
              badge.textContent = count > 99 ? '99+' : count;
              badge.classList.remove('hidden');
            }
            showNotificationToast(data);
          });
        } catch (err) {
          console.error('Socket init failed:', err);
        }
      }

      function getCookie(name) {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) return parts.pop().split(';').shift();
      }

      // Load conversations list
      async function loadConversations() {
        try {
          const res = await fetch('/api/v1/messages/conversations');
          const data = await res.json();
          if (data.status !== 'success') return;
          conversations = data.data.conversations;
          renderConversations();
        } catch (err) {
          console.error('Failed to load conversations:', err);
        }
      }

      function renderConversations() {
        const list = document.getElementById('conversationsList');
        if (conversations.length === 0) {
          list.innerHTML = '<div class="no-messages">No conversations yet. Start chatting from a user profile!</div>';
          return;
        }
        list.innerHTML = conversations.map(conv => `
          <div class="conversation-item${currentChatUser && currentChatUser._id === conv.user._id ? ' active' : ''}" onclick="openChat('${conv.user._id}', '${conv.user.name}', '${conv.user.photo || "default.jpg"}')">
            <div class="avatar">${conv.user.photo && conv.user.photo !== 'default.jpg' ? `<img src="${conv.user.photo}" alt="${conv.user.name}">` : conv.user.name.charAt(0).toUpperCase()}</div>
            <div class="info">
              <h4>${conv.user.name}</h4>
              <p>${conv.lastMessage.content}</p>
            </div>
            <div class="meta">
              <span>${formatTime(conv.lastMessage.createdAt)}</span>
              ${conv.unread > 0 ? `<div class="unread-badge">${conv.unread}</div>` : ''}
            </div>
          </div>
        `).join('');
      }

      function formatTime(date) {
        const d = new Date(date);
        const now = new Date();
        const diff = now - d;
        if (diff < 86400000) return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      async function openChat(userId, userName, userPhoto) {
        currentChatUser = { _id: userId, name: userName, photo: userPhoto };
        socket.emit('join_dm', userId);
        socket.emit('mark_read', { senderId: userId });

        document.getElementById('chatHeader').innerHTML = `
          <div class="avatar">${userPhoto && userPhoto !== 'default.jpg' ? `<img src="${userPhoto}" alt="${userName}">` : userName.charAt(0).toUpperCase()}</div>
          <div class="info"><a href="/user/${userId}"><h3>${userName}</h3></a></div>
        `;

        document.getElementById('messageInput').disabled = false;
        document.getElementById('sendBtn').disabled = false;
        document.getElementById('messageInput').focus();

        try {
          const res = await fetch(`/api/v1/messages/${userId}`);
          const data = await res.json();
          if (data.status !== 'success') return;

          const messagesDiv = document.getElementById('chatMessages');
          messagesDiv.innerHTML = '';
          data.data.messages.forEach(msg => {
            const type = msg.sender._id === '#{user._id}' ? 'sent' : 'received';
            appendMessage(msg, type);
          });
          messagesDiv.scrollTop = messagesDiv.scrollHeight;
        } catch (err) {
          console.error('Failed to load messages:', err);
        }

        renderConversations();
      }

      function appendMessage(msg, type) {
        const messagesDiv = document.getElementById('chatMessages');
        const div = document.createElement('div');
        div.className = `message ${type}`;
        div.innerHTML = `
          ${msg.content}
          <span class="time">${formatTime(msg.createdAt)}</span>
        `;
        messagesDiv.appendChild(div);
      }

      async function sendMessage() {
        const input = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const content = input.value.trim();
        if (!content) return;
        if (!currentChatUser) {
          alert('Please select a conversation first');
          return;
        }

        // Optimistically add message to UI
        const tempDiv = document.getElementById('chatMessages');
        const div = document.createElement('div');
        div.className = 'message sent';
        div.innerHTML = `${escapeHtml(content)}<span class="time">Just now</span>`;
        tempDiv.appendChild(div);
        tempDiv.scrollTop = tempDiv.scrollHeight;
        input.value = '';
        sendBtn.disabled = true;

        // Send via socket
        socket.emit('send_message', { recipientId: currentChatUser._id, content });
        sendBtn.disabled = false;
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      function showNotificationToast(data) {
        const toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:12px;padding:16px 20px;z-index:1000;display:flex;align-items:center;gap:12px;animation:slideIn 0.3s ease;cursor:pointer;max-width:320px;';
        const icon = data.type === 'like' ? '♥' : '💬';
        const action = data.type === 'like' ? 'liked your post' : 'commented on your post';
        toast.innerHTML = `<span style="font-size:20px;">${icon}</span><div><div style="font-size:13px;font-weight:600;">${escapeHtml(data.sender.name)}</div><div style="font-size:12px;color:var(--text-secondary);">${action}</div></div>`;
        toast.onclick = () => window.location.href = '/notifications';
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.animation = 'slideOut 0.3s ease'; setTimeout(() => toast.remove(), 300); }, 5000);
      }

      const animStyle = document.createElement('style');
      animStyle.textContent = '@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}@keyframes slideOut{from{transform:translateX(0);opacity:1}to{transform:translateX(100%);opacity:0}}';
      document.head.appendChild(animStyle);

      initSocket();
      loadConversations();

      async function resolvePreSelectedChat(userId) {
        try {
          const res = await fetch(`/api/v1/users/${userId}`);
          const data = await res.json();
          if (data.status === 'success' && data.data && data.data.user) {
            const u = data.data.user;
            openChat(u._id, u.name, u.photo || 'default.jpg');
          }
        } catch (err) {
          console.error('Failed to load pre-selected chat user:', err);
        }
      }

      // Handle pre-selected chat from URL param
      if (preSelectedChat && preSelectedChat !== 'null') {
        resolvePreSelectedChat(preSelectedChat);
      }
