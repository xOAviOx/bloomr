doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Home | Bloomr
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    style.
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #141414;
        --bg-tertiary: #1a1a1a;
        --text-primary: #f5f5f5;
        --text-secondary: #888888;
        --text-muted: #555555;
        --accent: #e63946;
        --accent-hover: #ff4d5a;
        --border: #2a2a2a;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Sora', sans-serif;
        background: var(--bg-primary);
        min-height: 100vh;
        color: var(--text-primary);
      }

      .background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        overflow: hidden;
      }

      .background::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(ellipse at 20% 20%, rgba(230, 57, 70, 0.06) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 80%, rgba(230, 57, 70, 0.04) 0%, transparent 50%);
        animation: drift 20s ease-in-out infinite;
      }

      @keyframes drift {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(2%, 2%) rotate(1deg); }
      }

      .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .nav {
        display: flex;
        gap: 24px;
        align-items: center;
      }

      .nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
      }

      .nav a:hover {
        color: var(--text-primary);
      }

      .nav a.active {
        color: var(--accent);
      }

      .logout-btn {
        padding: 8px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 13px;
        transition: all 0.3s ease;
      }

      .logout-btn:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 640px;
        margin: 0 auto;
        padding: 100px 20px 40px;
      }

      .feed-header {
        margin-bottom: 32px;
      }

      .feed-header h1 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .feed-header p {
        color: var(--text-secondary);
        font-size: 14px;
      }

      .post-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        animation: fadeIn 0.5s ease;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .post-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }

      .avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 16px;
        color: var(--accent);
        overflow: hidden;
      }

      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .user-info h3 {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 2px;
      }

      .user-info span {
        font-size: 12px;
        color: var(--text-muted);
      }

      .post-content {
        font-size: 15px;
        line-height: 1.6;
        color: var(--text-primary);
        margin-bottom: 16px;
      }

      .post-image {
        width: 100%;
        border-radius: 12px;
        margin-bottom: 16px;
        display: none;
      }

      .post-actions {
        display: flex;
        gap: 24px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .action-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-family: 'Sora', sans-serif;
        font-size: 13px;
        cursor: pointer;
        transition: color 0.3s ease;
      }

      .action-btn:hover {
        color: var(--accent);
      }

      .action-btn.liked {
        color: var(--accent);
      }

      .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary);
      }

      .empty-state h2 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 20px;
        margin-bottom: 8px;
        color: var(--text-primary);
      }

      .create-post-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--accent);
        border: none;
        color: white;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(230, 57, 70, 0.4);
        transition: all 0.3s ease;
        z-index: 50;
      }

      .create-post-btn:hover {
        background: var(--accent-hover);
        transform: scale(1.1);
      }

      .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 200;
        align-items: center;
        justify-content: center;
      }

      .modal-overlay.active {
        display: flex;
      }

      .modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
        width: 100%;
        max-width: 500px;
        margin: 20px;
        animation: slideUp 0.3s ease;
      }

      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .modal h2 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 20px;
        margin-bottom: 24px;
      }

      .modal textarea {
        width: 100%;
        height: 120px;
        padding: 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 15px;
        resize: none;
        outline: none;
        margin-bottom: 16px;
      }

      .modal textarea:focus {
        border-color: var(--accent);
      }

      .modal textarea::placeholder {
        color: var(--text-muted);
      }

      .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
      }

      .modal-btn {
        padding: 12px 24px;
        border-radius: 10px;
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .modal-btn.cancel {
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        color: var(--text-secondary);
      }

      .modal-btn.cancel:hover {
        background: var(--border);
      }

      .modal-btn.submit {
        background: var(--accent);
        border: none;
        color: white;
      }

      .modal-btn.submit:hover {
        background: var(--accent-hover);
      }

      .modal-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      @media (max-width: 480px) {
        .container {
          padding: 80px 16px 40px;
        }

        .post-card {
          padding: 16px;
        }
      }
  body
    .background
    .header
      .logo Bloomr
      .nav
        a(href="/home" class="active") Home
        a(href="/profile") Profile
        a.logout-btn(href="/logout") Logout

  .container
    .feed-header
      h1 Your Feed
      p See what others are sharing

    if posts && posts.length > 0
      each post, index in posts
        .post-card(style=`animation-delay: ${index * 0.1}s`)
          .post-header
            .avatar
              if post.userID && post.userID.photo && post.userID.photo !== 'default.jpg'
                img(src=post.userID.photo alt=user.name)
              else
                | #{post.userID ? post.userID.name.charAt(0).toUpperCase() : '?'}
            .user-info
              h3= post.userID ? post.userID.name : 'Unknown'
              span= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
          .post-content
              = post.content
          .post-actions
            button.action-btn.like-btn
              span ♥
              span= post.likes ? post.likes.length : 0
            button.action-btn.comment-btn
              span 💬
              span Comment
    else
      .empty-state
        h2 No posts yet
        p Be the first to share something!

  .modal-overlay#createPostModal
    .modal
      h2 Create Post
      form(action="/create-post" method="POST" id="createPostForm")
        textarea(name="content" placeholder="What's on your mind?" required maxlength="500")
        .modal-actions
          button(type="button").modal-btn.cancel Cancel
          button(type="submit").modal-btn.submit Post

  script.
    const modal = document.getElementById('createPostModal');
    const openBtn = document.querySelector('.create-post-btn');
    const cancelBtn = document.querySelector('.modal-btn.cancel');
    const form = document.getElementById('createPostForm');

    openBtn.addEventListener('click', () => {
      modal.classList.add('active');
    });

    cancelBtn.addEventListener('click', () => {
      modal.classList.remove('active');
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.remove('active');
      }
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        modal.classList.remove('active');
      }
    });

  button.create-post-btn(type="button") +