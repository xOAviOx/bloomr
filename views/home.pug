doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Home | Bloomr
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    style.
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #141414;
        --bg-tertiary: #1a1a1a;
        --text-primary: #f5f5f5;
        --text-secondary: #888888;
        --text-muted: #555555;
        --accent: #e63946;
        --accent-hover: #ff4d5a;
        --border: #2a2a2a;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Sora', sans-serif;
        background: var(--bg-primary);
        min-height: 100vh;
        color: var(--text-primary);
      }
      .background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        background: radial-gradient(ellipse at 20% 20%, rgba(230, 57, 70, 0.06) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 80%, rgba(230, 57, 70, 0.04) 0%, transparent 50%);
      }
      .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 24px;
        font-weight: 700;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav { display: flex; gap: 24px; align-items: center; }
      .nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
      }
      .nav a:hover, .nav a.active { color: var(--accent); }
      .logout-btn {
        padding: 8px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 13px;
        transition: all 0.3s ease;
      }
      .logout-btn:hover { background: var(--accent); border-color: var(--accent); color: white; }
      .container {
        position: relative;
        z-index: 1;
        max-width: 640px;
        margin: 0 auto;
        padding: 100px 20px 40px;
      }
      .feed-header { margin-bottom: 32px; }
      .feed-header h1 { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 600; margin-bottom: 8px; }
      .feed-header p { color: var(--text-secondary); font-size: 14px; }
      .post-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
      }
      .post-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
      .avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 16px;
        color: var(--accent);
      }
      .user-info h3 { font-size: 15px; font-weight: 600; margin-bottom: 2px; }
      .user-info span { font-size: 12px; color: var(--text-muted); }
      .post-content { font-size: 15px; line-height: 1.6; color: var(--text-primary); margin-bottom: 16px; }
      .post-actions {
        display: flex;
        gap: 24px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }
      .action-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-family: 'Sora', sans-serif;
        font-size: 13px;
        cursor: pointer;
        transition: color 0.3s ease;
      }
      .action-btn:hover, .action-btn.liked { color: var(--accent); }
      .empty-state { text-align: center; padding: 60px 20px; color: var(--text-secondary); }
      .empty-state h2 { font-family: 'Space Grotesk', sans-serif; font-size: 20px; margin-bottom: 8px; color: var(--text-primary); }
      .create-post-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--accent);
        border: none;
        color: white;
        font-size: 28px;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(230, 57, 70, 0.4);
        transition: all 0.3s ease;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
      }
      .create-post-btn:hover { background: var(--accent-hover); transform: scale(1.1); }
      .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 200;
      }
      .modal-overlay.active { display: flex; align-items: center; justify-content: center; }
      .modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
        width: 100%;
        max-width: 500px;
        margin: 20px;
      }
      .modal h2 { font-family: 'Space Grotesk', sans-serif; font-size: 20px; margin-bottom: 24px; }
      .modal textarea {
        width: 100%;
        height: 120px;
        padding: 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 15px;
        resize: none;
        outline: none;
        margin-bottom: 16px;
      }
      .modal textarea:focus { border-color: var(--accent); }
      .modal textarea::placeholder { color: var(--text-muted); }
      .modal-actions { display: flex; gap: 12px; justify-content: flex-end; }
      .modal-btn {
        padding: 12px 24px;
        border-radius: 10px;
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .modal-btn.cancel { background: var(--bg-tertiary); border: 1px solid var(--border); color: var(--text-secondary); }
      .modal-btn.cancel:hover { background: var(--border); }
      .modal-btn.submit { background: var(--accent); border: none; color: white; }
      .modal-btn.submit:hover { background: var(--accent-hover); }
      .comment-section { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); }
      .comment-form { display: flex; gap: 12px; }
      .comment-form input {
        flex: 1;
        padding: 10px 14px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 13px;
        outline: none;
      }
      .comment-form input:focus { border-color: var(--accent); }
      .comment-form button {
        padding: 10px 16px;
        background: var(--accent);
        border: none;
        border-radius: 10px;
        color: white;
        font-family: 'Sora', sans-serif;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
      }
      .comment-form button:hover { background: var(--accent-hover); }
      .comment-list { margin-top: 12px; }
      .comment-item { display: flex; gap: 10px; margin-bottom: 10px; }
      .comment-item .avatar { width: 32px; height: 32px; font-size: 12px; }
      .comment-item .comment-body { flex: 1; }
      .comment-item .comment-user { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
      .comment-item .comment-text { font-size: 13px; color: var(--text-secondary); }
      .chatbot-btn {
        padding: 8px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        font-family: 'Sora', sans-serif;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .chatbot-btn:hover { background: var(--accent); border-color: var(--accent); color: white; }
      .chatbot-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 300;
      }
      .chatbot-modal-overlay.active { display: flex; align-items: flex-end; justify-content: flex-end; padding: 20px; }
      .chatbot-modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 20px;
        width: 100%;
        max-width: 420px;
        height: 560px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .chatbot-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .chatbot-header h3 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; display: flex; align-items: center; gap: 8px; }
      .chatbot-close {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 20px;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
      }
      .chatbot-close:hover { color: var(--accent); }
      .chatbot-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .chat-message { display: flex; flex-direction: column; gap: 4px; }
      .chat-message.user { align-items: flex-end; }
      .chat-message.assistant { align-items: flex-start; }
      .chat-bubble {
        max-width: 80%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 14px;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
      }
      .chat-message.user .chat-bubble {
        background: var(--accent);
        color: white;
        border-bottom-right-radius: 4px;
      }
      .chat-message.assistant .chat-bubble {
        background: var(--bg-tertiary);
        color: var(--text-primary);
        border-bottom-left-radius: 4px;
      }
      .chat-sources { margin-top: 8px; padding: 10px 14px; background: var(--bg-tertiary); border-radius: 10px; font-size: 12px; color: var(--text-secondary); }
      .chat-sources strong { color: var(--text-primary); }
      .chat-input-area {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        gap: 12px;
      }
      .chat-input-area input {
        flex: 1;
        padding: 12px 16px;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        outline: none;
      }
      .chat-input-area input:focus { border-color: var(--accent); }
      .chat-input-area button {
        padding: 12px 20px;
        background: var(--accent);
        border: none;
        border-radius: 12px;
        color: white;
        font-family: 'Sora', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s ease;
      }
      .chat-input-area button:hover { background: var(--accent-hover); }
      .chat-input-area button:disabled { opacity: 0.5; cursor: not-allowed; }
      .chat-loading { display: flex; align-items: center; gap: 8px; color: var(--text-secondary); font-size: 13px; padding: 8px 0; }
      .chat-loading::after { content: ''; width: 16px; height: 16px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
  body
    .background
    .header
      .logo Bloomr
      .nav
        a(href="/home" class="active") Home
        a(href="/internships") Internships
        a(href="/profile") Profile
        a.logout-btn(href="/logout") Logout
        button.chatbot-btn(type="button" onclick="openChatbot()") 🤖
    .container
      .feed-header
        h1 Your Feed
        p See what others are sharing
      if posts && posts.length > 0
        each post in posts
          .post-card
            .post-header
              a(href=`/user/${post.userID._id}` style="text-decoration: none; color: inherit; display: contents;")
                .avatar= post.userID ? post.userID.name.charAt(0).toUpperCase() : '?'
                .user-info
                  h3= post.userID ? post.userID.name : 'Unknown'
                  span= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
            .post-content= Array.isArray(post.content) ? post.content.join(' ') : post.content
            .post-actions
              button.action-btn.like-btn(data-post-id=post._id) ♥ #{post.likes ? post.likes.length : 0}
              button.action-btn.comment-toggle(data-post-id=post._id) 💬 #{post.comments ? post.comments.length : 0}
            .comment-section(id=`comment-section-${post._id}` style="display: none;")
              .comment-form
                input(type="text" placeholder="Write a comment..." class="comment-input" data-post-id=post._id)
                button.comment-submit(data-post-id=post._id) Post
              .comment-list
                each comment in (post.comments || [])
                  .comment-item
                    a(href=`/user/${comment.userID._id}` style="text-decoration: none; color: inherit; display: contents;")
                      .avatar= comment.userID ? (comment.userID.name ? comment.userID.name.charAt(0).toUpperCase() : '?') : '?'
                    .comment-body
                      a(href=`/user/${comment.userID._id}` style="text-decoration: none; color: inherit;")
                        .comment-user= comment.userID ? (comment.userID.name || 'Unknown') : 'Unknown'
                      .comment-text= comment.content
      else
        .empty-state
          h2 No posts yet
          p Be the first to share something!
    .modal-overlay#createPostModal
      .modal
        h2 Create Post
        form(action="/create-post" method="POST")
          textarea(name="content" placeholder="What's on your mind?" required maxlength="500")
          .modal-actions
            button(type="button" onclick="document.getElementById('createPostModal').classList.remove('active')").modal-btn.cancel Cancel
            button(type="submit").modal-btn.submit Post
    button.create-post-btn(type="button" onclick="document.getElementById('createPostModal').classList.add('active')") +
    .chatbot-modal-overlay#chatbotModal
      .chatbot-modal
        .chatbot-header
          h3 🤖 Bloomr Chatbot
          button.chatbot-close(type="button" onclick="closeChatbot()") ×
        .chatbot-messages#chatMessages
          .chat-message.assistant
            .chat-bubble Welcome! Ask me anything about the posts on Bloomr. For example: "what are people talking about?" or "who posted about football?"
        .chat-input-area
          input(type="text" id="chatInput" placeholder="Ask about posts..." onkeypress="if(event.key==='Enter')sendChatMessage()")
          button(type="button" onclick="sendChatMessage()" id="chatSendBtn") Send
    script.
      // Like button handler
      document.querySelectorAll('.like-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const postId = btn.dataset.postId;
          try {
            const res = await fetch(`/api/v1/posts/${postId}/like`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();
            if (data.status === 'success') {
              btn.textContent = `♥ ${data.data.likeCount}`;
              if (data.data.isLiked) {
                btn.classList.add('liked');
              } else {
                btn.classList.remove('liked');
              }
            }
          } catch (err) {
            console.error('Like failed:', err);
          }
        });
      });

      // Comment toggle handler
      document.querySelectorAll('.comment-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const postId = btn.dataset.postId;
          const section = document.getElementById(`comment-section-${postId}`);
          section.style.display = section.style.display === 'none' ? 'block' : 'none';
        });
      });

      // Comment submit handler
      document.querySelectorAll('.comment-submit').forEach(btn => {
        btn.addEventListener('click', async () => {
          const postId = btn.dataset.postId;
          const input = document.querySelector(`.comment-input[data-post-id="${postId}"]`);
          const content = input.value.trim();
          if (!content) return;
          try {
            const res = await fetch(`/api/v1/posts/${postId}/comment`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content })
            });
            const data = await res.json();
            if (data.status === 'success') {
              input.value = '';
              const commentList = document.querySelector(`#comment-section-${postId} .comment-list`);
              const newComment = document.createElement('div');
              newComment.className = 'comment-item';
              newComment.innerHTML = `
                <div class="avatar">${data.data.comment.userID ? data.data.comment.userID.name.charAt(0).toUpperCase() : '?'}</div>
                <div class="comment-body">
                  <div class="comment-user">${data.data.comment.userID ? data.data.comment.userID.name : 'Unknown'}</div>
                  <div class="comment-text">${data.data.comment.content}</div>
                </div>
              `;
              commentList.appendChild(newComment);
            }
          } catch (err) {
            console.error('Comment failed:', err);
          }
        });
      });

      // Enter key for comment input
      document.querySelectorAll('.comment-input').forEach(input => {
        input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            const postId = input.dataset.postId;
            document.querySelector(`.comment-submit[data-post-id="${postId}"]`).click();
          }
        });
      });

      // Chatbot functions
      function openChatbot() {
        document.getElementById('chatbotModal').classList.add('active');
      }

      function closeChatbot() {
        document.getElementById('chatbotModal').classList.remove('active');
      }

      async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const sendBtn = document.getElementById('chatSendBtn');
        const question = input.value.trim();
        if (!question) return;

        const messagesDiv = document.getElementById('chatMessages');

        // Add user message
        const userMsg = document.createElement('div');
        userMsg.className = 'chat-message user';
        userMsg.innerHTML = `<div class="chat-bubble">${escapeHtml(question)}</div>`;
        messagesDiv.appendChild(userMsg);

        input.value = '';
        sendBtn.disabled = true;

        // Add loading indicator
        const loading = document.createElement('div');
        loading.className = 'chat-message assistant';
        loading.innerHTML = '<div class="chat-loading">Thinking...</div>';
        messagesDiv.appendChild(loading);

        try {
          const res = await fetch('/api/v1/chatbot/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ question })
          });
          const data = await res.json();
          loading.remove();

          if (data.status === 'success') {
            const botMsg = document.createElement('div');
            botMsg.className = 'chat-message assistant';
            let sourcesHtml = '';
            if (data.data.sources && data.data.sources.length > 0) {
              sourcesHtml = `<div class="chat-sources"><strong>Sources:</strong> ${data.data.sources.map(s => s.preview).join(' | ')}</div>`;
            }
            botMsg.innerHTML = `<div class="chat-bubble">${escapeHtml(data.data.answer)}</div>${sourcesHtml}`;
            messagesDiv.appendChild(botMsg);
          } else {
            const errMsg = document.createElement('div');
            errMsg.className = 'chat-message assistant';
            errMsg.innerHTML = `<div class="chat-bubble">Error: ${escapeHtml(data.message || 'Something went wrong')}</div>`;
            messagesDiv.appendChild(errMsg);
          }
        } catch (err) {
          loading.remove();
          const errMsg = document.createElement('div');
          errMsg.className = 'chat-message assistant';
          errMsg.innerHTML = `<div class="chat-bubble">Failed to get response. Please try again.</div>`;
          messagesDiv.appendChild(errMsg);
        }

        sendBtn.disabled = false;
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }